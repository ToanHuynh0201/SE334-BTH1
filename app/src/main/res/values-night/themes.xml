<resources>
    <!-- Dark Mode Theme - Modern Material Design -->
    <style name="Theme.BTTH1" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Primary brand color (lighter for dark mode) -->
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorPrimaryVariant">@color/md_primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorSecondaryVariant">@color/md_secondary</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>

        <!-- Tertiary color -->
        <item name="colorTertiary">@color/md_tertiary</item>
        <item name="colorOnTertiary">@color/text_on_primary</item>

        <!-- Background and surface -->
        <item name="android:colorBackground">@color/surface_light</item>
        <item name="colorSurface">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/md_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/surface_light</item>

        <!-- Material Components -->
        <item name="materialButtonStyle">@style/Widget.BTTH1.Button</item>
    </style>

    <!-- Custom Button Styles -->
    <style name="Widget.BTTH1.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>