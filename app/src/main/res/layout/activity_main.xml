<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_light"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Header with App Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_primary"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="22dp"
        android:paddingEnd="20dp"
        android:paddingBottom="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="@color/text_on_primary"
            android:letterSpacing="0.015" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:alpha="0.92"
            android:text="@string/app_tagline"
            android:textColor="@color/text_on_primary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Main Content Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <!-- Connection State Card -->
            <com.example.btth1.ui.ConnectionStateView
                android:id="@+id/connectionStateView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp" />

            <!-- Discover Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDiscover"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="14dp"
                android:text="@string/discover_peers"
                android:textSize="14sp"
                android:letterSpacing="0.05"
                app:cornerRadius="8dp"
                app:elevation="2dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

            <!-- Nearby Devices Section Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="10dp"
                android:text="@string/nearby_devices"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/md_primary"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <!-- Peers List Container -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@color/surface_variant"
                android:outlineProvider="background"
                app:elevation="1dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPeers"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingStart="8dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="8dp" />

                <com.example.btth1.ui.PeerListStateView
                    android:id="@+id/peerListStateView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Action Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <!-- Push to Talk Button (Primary CTA) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTalk"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/push_to_talk"
            android:textSize="16sp"
            android:textStyle="bold"
            android:enabled="false"
            android:letterSpacing="0.05"
            app:cornerRadius="12dp"
            app:elevation="3dp"
            app:backgroundTint="@color/md_primary" />

        <!-- Hint Text -->
        <TextView
            android:id="@+id/tvTalkHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/talk_hint_disconnected"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:letterSpacing="0.02" />

    </LinearLayout>

</LinearLayout>
